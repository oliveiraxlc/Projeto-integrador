create table calendario(
    calendario_id serial primary key,
    titulo        varchar(150),
    descricao     text,
    data_hora     timestamp,
    tipo_evento   varchar(50),
    turmas_id     int,
    foreign key (turmas_id) references turmas(turmas_id),
    constraint chk_tipo_evento check (tipo_evento in ('Prova', 'Entrega de Atividade', 'Evento Escolar', 'Feriado'))
);

create table atividades(
    atividades_id serial primary key,
    titulo        varchar(100),
    descricao     text,
    data_entrega  timestamp,
    professor_id  int,
    foreign key (professor_id) references usuarios(usuarios_id),
    turmas_id     int,
    foreign key (turmas_id) references turmas(turmas_id),
    calendario_id int,
    foreign key (calendario_id) references calendario(calendario_id)
);

create table conclusao_atividades(
    conclusao_id   serial primary key,
    aluno_id       int,
    foreign key (aluno_id) references usuarios(usuarios_id),
    atividades_id  int,
    foreign key (atividades_id) references atividades(atividades_id),
    data_entrega   timestamp,
    status         varchar(25) not null default 'Pendente',
    pontos_obtidos smallint not null default 0,
    constraint chk_status check (status in ('Pendente', 'Entrega Antecipada', 'Entregue no Prazo', 'Entregue com Atraso', 'Nao Entregue')),
    constraint chk_pontos check (pontos_obtidos in (0, 5, 10, 15)),
    unique (aluno_id, atividades_id)
);

create table pontos(
    pontos_id     serial primary key,
    aluno_id      int,
    foreign key (aluno_id) references usuarios(usuarios_id),
    atividades_id int,
    foreign key (atividades_id) references conclusao_atividades(conclusao_id),
    quantidade    int not null default 0,
    motivo        text,
    data_ganho    timestamp not null default now()
);

