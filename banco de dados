create database lgds;

create table unidades(
    unidades_id serial primary key,
    nome varchar(100),
    cidade varchar(100),
    estado char(2)
);

create table cursos(
    cursos_id serial primary key,
    nome varchar(100),
    descricao text,
    unidades_id int,
    foreign key (unidades_id) references unidades(unidades_id)
);

create table turmas(
    turmas_id serial primary key,
    codigo_turma varchar(50) unique,
    ano smallint,
    turno varchar(20),
    cursos_id int,
    foreign key (cursos_id) references cursos(cursos_id),
    constraint chk_turno check (turno in ('Matutino', 'Vespertino', 'Noturno'))
);

create table usuarios(
    usuarios_id      serial primary key,
    nome varchar(100) not null,
    email varchar(150) not null unique,
    senha varchar(255) not null,
    tipo_usuario varchar(15)  not null,
    turmas_id int,
    foreign key (turmas_id) references turmas(turmas_id),
    constraint chk_tipo_usuario check (tipo_usuario in ('Admin', 'Professor', 'Aluno')),
    nickname_anonimo varchar(20) unique,
    pontos_totais int not null default 0,
    nivel  varchar(30) not null default 'Iniciante',
    constraint chk_nivel check (nivel in ('Iniciante', 'Organizado', 'Focado', 'Mestre do Prazo', 'Elite Academica'))
);

create table niveis_pontuacao(
    niveis_id  serial primary key,
    nome  varchar(30) not null unique,
    pts_minimo int not null,
    pts_maximo int,
    descricao  text
);

